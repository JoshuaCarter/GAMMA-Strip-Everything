--[[
	Dorn's Fieldstrip All Keybind

	MCM keybind that field-strips whatever weapon your cursor is over in an
	inventory list - your own gear, a corpse or crate you're looting, a trade
	screen, etc - detaching every addon (scope, silencer, grenade launcher)
	in one press.

	Hover tracking piggybacks on the same ActorMenu_on_item_focus_receive /
	_lost callbacks the inventory UI itself fires when the cursor moves over
	a cell, so it works anywhere those fire - no dependency on which bag/menu
	mode is active. Detaching reuses ui_inventory.GUI:Action_Detach_Scope /
	_Silencer / _GL - the exact functions the right-click "Detach ..." menu
	entries call - so results (items returned, sounds played, UI refresh)
	are identical to using that menu three times.

	Key detection: the inventory/loot/trade window (ui_inventory.UIInventory
	- one class handles all three via self.mode) owns keyboard focus while
	it's open and never forwards to the global on_key_press/on_before_key_press
	callback bus, so those don't fire while hovering an item. Instead we wrap
	UIInventory:OnKeyboard directly (same technique Dorns_Optimal_Tool_Use
	uses on item_parts functions) - guaranteed to see every keypress the
	window receives, regardless of mode. The global callbacks are also
	registered as a harmless fallback in case some other menu variant
	doesn't route through UIInventory at all.

	Loads late (zzzz_) so any other mod's ui_inventory/utils_item patches are
	already in place before we call into them.
]]

local MOD_ID = "dorn_fieldstrip_all_keybind"
local DORN_COMMON_VERSION = "dorn_common_105895da" -- managed by sync-dorn-common.sh, do not hand-edit

local DORN

local CONFIG = {
	key = nil,
	debug_log = false,
}

local hovered_obj_id = nil
local orig_on_keyboard = nil

local function log(msg)
	if not (DORN and DORN.dbg) then
		return
	end
	if CONFIG.debug_log then
		DORN.dbg.log(MOD_ID, tostring(msg))
	end
end

local function on_option_change()
	CONFIG.key = DORN.mcm.key(MOD_ID, "main/key")
	CONFIG.debug_log = DORN.mcm.bool(MOD_ID, "development/debug_log", false)
	log(string.format("config: key=%s debug_log=%s", tostring(CONFIG.key), tostring(CONFIG.debug_log)))
end

local function on_item_focus_receive(obj)
	hovered_obj_id = obj and obj:id() or nil
	if obj then
		log(string.format("hover: %s (id=%s)", obj:section(), tostring(hovered_obj_id)))
	end
end

local function on_item_focus_lost(obj)
	if obj and hovered_obj_id == obj:id() then
		log(string.format("hover lost: %s", obj:section()))
		hovered_obj_id = nil
	end
end

-- Menu mode changes (opening/closing/switching inventory-family screens)
-- are a clean point to drop any stale hover state.
local function on_before_init_mode()
	hovered_obj_id = nil
end

local function get_hovered_weapon()
	if not hovered_obj_id then
		return nil
	end
	local obj = level.object_by_id(hovered_obj_id)
	if not obj then
		log("hovered object no longer resolves (id " .. tostring(hovered_obj_id) .. ")")
		return nil
	end
	if not obj:parent() then
		log(string.format("%s: no parent, skipping", obj:section()))
		return nil
	end
	if not IsWeapon(obj) then
		log(string.format("%s: not a weapon, skipping", obj:section()))
		return nil
	end
	return obj
end

local function field_strip(gui, obj)
	local stripped = 0

	if utils_item.get_attached_scope(obj) then
		log(string.format("%s: detaching scope", obj:section()))
		gui:Action_Detach_Scope(obj)
		stripped = stripped + 1
		obj = get_hovered_weapon() or obj
	end

	if obj and utils_item.get_attached_silencer(obj) then
		log(string.format("%s: detaching silencer", obj:section()))
		gui:Action_Detach_Silencer(obj)
		stripped = stripped + 1
		obj = get_hovered_weapon() or obj
	end

	if obj and utils_item.get_attached_gl(obj) then
		log(string.format("%s: detaching gl", obj:section()))
		gui:Action_Detach_GL(obj)
		stripped = stripped + 1
	end

	return stripped
end

local function try_field_strip()
	local gui = ui_inventory and ui_inventory.GUI
	if not gui then
		log("ui_inventory.GUI not available")
		return
	end

	local obj = get_hovered_weapon()
	if not obj then
		log("no weapon hovered")
		return
	end

	local sec = obj:section()
	local stripped = field_strip(gui, obj)
	if stripped > 0 then
		log(string.format("%s: removed %d addon(s)", sec, stripped))
	else
		log(string.format("%s: nothing attached", sec))
	end
end

local function handle_key(key)
	log(string.format("key seen: dik=%s configured=%s", tostring(key), tostring(CONFIG.key)))
	if CONFIG.key and key == CONFIG.key then
		try_field_strip()
	end
end

local function on_key_press(key)
	handle_key(key)
end

-- Fires for every key the inventory/loot/trade window receives, regardless
-- of self.mode, since they all share this one UIInventory class/instance.
local function patched_on_keyboard(self, dik, keyboard_action)
	if keyboard_action == ui_events.WINDOW_KEY_PRESSED then
		handle_key(dik)
	end
	return orig_on_keyboard(self, dik, keyboard_action)
end

local function patch_ui_inventory()
	if not (ui_inventory and ui_inventory.UIInventory and ui_inventory.UIInventory.OnKeyboard) then
		log("ui_inventory.UIInventory.OnKeyboard not found, keybind will only use the global callback fallback")
		return
	end
	orig_on_keyboard = ui_inventory.UIInventory.OnKeyboard
	ui_inventory.UIInventory.OnKeyboard = patched_on_keyboard
	log("patched ui_inventory.UIInventory.OnKeyboard")
end

function on_game_start()
	DORN = _G[DORN_COMMON_VERSION].load(MOD_ID)

	RegisterScriptCallback("on_option_change", on_option_change)
	RegisterScriptCallback("ActorMenu_on_item_focus_receive", on_item_focus_receive)
	RegisterScriptCallback("ActorMenu_on_item_focus_lost", on_item_focus_lost)
	RegisterScriptCallback("ActorMenu_on_before_init_mode", on_before_init_mode)
	RegisterScriptCallback("on_before_key_press", on_key_press)
	RegisterScriptCallback("on_key_press", on_key_press)

	patch_ui_inventory()

	log("loaded")
end
