--[[
	Dorn's Strip Everything - companion loot safety.

	Block moving equipped player gear into a companion's inventory during loot.
	Those transfers use raw transfer_item and can make items vanish.
]]

local MOD_ID = "dorn_strip_everything"
local DORN_COMMON_VERSION = "dorn_common_c62f913d" -- managed by sync-dorn-common.sh, do not hand-edit

local DORN

local CONFIG = {
	block_special_items = true,
}

local ACTOR_SOURCE_BAGS = {
	[EDDListType.iActorBag] = true,
	[EDDListType.iActorSlot] = true,
	[EDDListType.iActorBelt] = true,
}

local function log(msg)
	if not (DORN and DORN.dbg) then
		return
	end
	if DORN.mcm.bool(MOD_ID, "development/debug_log", false) then
		DORN.dbg.log(MOD_ID, tostring(msg))
	end
end

local function on_option_change()
	CONFIG.block_special_items = DORN.mcm.bool(MOD_ID, "main/block_companion_special_items", true)
	log(string.format("companion loot: block_special_items=%s", tostring(CONFIG.block_special_items)))
end

local function is_companion(npc)
	return npc
		and IsStalker(npc)
		and npc:alive()
		and npc:has_info("npcx_is_companion")
end

local function is_strapped_weapon(obj)
	return IsWeapon(obj)
		and se_load_var
		and se_load_var(obj:id(), nil, "strapped_item")
end

local function is_actor_equipped_or_strapped(obj)
	if not (db.actor and obj) then
		return false
	end

	local obj_id = obj:id()
	for slot = 1, 13 do
		local slot_item = db.actor:item_in_slot(slot)
		if slot_item and slot_item:id() == obj_id then
			return true
		end
	end

	if db.actor.is_on_belt and db.actor:is_on_belt(obj) then
		return true
	end

	return is_strapped_weapon(obj)
end

local function is_actor_to_companion_move(mode, bag)
	return mode == "loot" and ACTOR_SOURCE_BAGS[bag]
end

local function on_item_before_move(flags, npc_id, obj, mode, bag)
	if _G.dorn_strip_internal_move then
		return
	end
	if not CONFIG.block_special_items then
		return
	end
	if not (flags and npc_id and obj) then
		return
	end
	if not is_actor_to_companion_move(mode, bag) then
		return
	end
	if not is_actor_equipped_or_strapped(obj) then
		return
	end

	local npc = get_object_by_id(npc_id)
	if not is_companion(npc) then
		return
	end

	flags.ret_value = false
	if not (obj.section and obj.id) then
		return
	end
	local npc_name = (npc.name and npc:name()) or "companion"
	log(string.format(
		"companion loot: blocked player -> companion %s id=%s with %s",
		obj:section(), tostring(obj:id()), npc_name
	))
end

function on_game_start()
	DORN = _G[DORN_COMMON_VERSION].load(MOD_ID)
	RegisterScriptCallback("on_option_change", on_option_change)
	RegisterScriptCallback("ActorMenu_on_item_before_move", on_item_before_move)
	on_option_change()
	log("companion loot: loaded")
end
